generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String     @id @default(cuid())
  name             String?
  email            String     @unique
  username         String     @unique
  password         String
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @default(now()) @updatedAt
  banReason        String?
  deletedAt        DateTime?
  isBanned         Boolean    @default(false)
  role             Role       @default(USER)
  isVerified       Boolean    @default(false)
  verificationType String?
  auditLogs        AuditLog[] @relation("AdminActions")
  rooms            Room[]

  @@index([username])
}

model Room {
  id               String         @id @default(cuid())
  userId           String
  theme            String         @default("dark")
  backgroundColor  String?        @default("#050505")
  primaryColor     String?        @default("#ffffff")
  fontStyle        String?        @default("sans")
  backgroundImage  String?
  backgroundEffect String?        @default("none")
  customCursor     String?        @default("auto")
  customFont       String?        @default("Inter")
  mouseTrails      String?        @default("none")
  updatedAt        DateTime       @default(now()) @updatedAt
  staticTexture    String?        @default("none")
  avatarUrl        String?
  createdAt        DateTime       @default(now())
  deletedAt        DateTime?
  title            String         @default("Meu Espaço")
  slug             String?        @unique
  isPrimary        Boolean        @default(true)
  type             RoomType       @default(PERMANENT)
  expiresAt        DateTime?
  maxViews         Int?
  blocks           MoodBlock[]
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  analytics        RoomAnalytics?
  versions         RoomVersion[]

  @@index([userId])
  @@index([slug])
}

model RoomVersion {
  id          String   @id @default(cuid())
  roomId      String
  blocks      Json
  profileData Json?
  isActive    Boolean  @default(false)
  label       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([roomId, isActive])
}

model MoodBlock {
  id        String             @id @default(cuid())
  type      String
  content   Json
  order     Int                @default(0)
  height    Int?
  rotation  Float              @default(0)
  updatedAt DateTime           @default(now()) @updatedAt
  width     Int?
  x         Float              @default(0)
  y         Float              @default(0)
  zIndex    Int                @default(1)
  createdAt DateTime           @default(now())
  deletedAt DateTime?
  isHidden  Boolean            @default(false)
  isLocked  Boolean            @default(false)
  groupId   String?
  roomId    String
  messages  GuestbookMessage[]
  room      Room               @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([roomId, type])
  @@index([groupId])
}

model GuestbookMessage {
  id        String    @id @default(cuid())
  content   String
  author    String
  isAdmin   Boolean   @default(false)
  blockId   String
  userId    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  block     MoodBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@index([blockId])
}

model RoomAnalytics {
  id         String    @id @default(cuid())
  roomId     String    @unique
  views      Int       @default(0)
  lastViewAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now()) @updatedAt
  room       Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  isEnabled   Boolean  @default(true)
  isPremium   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetId   String?
  targetType String?
  reason     String?
  metadata   Json?
  createdAt  DateTime @default(now())
  admin      User     @relation("AdminActions", fields: [adminId], references: [id])

  @@index([adminId])
  @@index([action])
  @@index([targetId])
}

enum Role {
  USER
  CURATOR
  MODERATOR
  ADMIN
}

enum RoomType {
  PERMANENT
  TEMPORARY
}
